          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"feedback\": \"REJECTED\",\n  \"notes\": \"Not what I was looking for.\"\n}"
        },
        "url": {
          "raw": "http://localhost:8080/api/ai/project-assistant/feedback/1",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["api", "ai", "project-assistant", "feedback", "1"]
        }
