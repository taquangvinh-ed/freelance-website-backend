    {
      "name": "Get History",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "http://localhost:8080/api/ai/project-assistant/history?page=0&size=10",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
